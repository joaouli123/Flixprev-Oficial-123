# Configurações do Supabase
# Copie este arquivo para .env e preencha com suas credenciais reais
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_API_BASE_URL=https://flixprev-oficial-123-production.up.railway.app

# Banco de dados PostgreSQL (Neon/Supabase Postgres)
# Necessário para histórico persistente, isolamento por usuário e RAG vetorial completo
DATABASE_URL=postgresql://user:password@host:5432/database

# OpenAI (necessário para embeddings e melhor análise de anexos/imagens)
OPENAI_API_KEY=your_openai_key_here

# Gemini (OpenAI-compatible endpoint) - opção rápida recomendada
GEMINI_API_KEY=your_gemini_key_here
AI_INTEGRATIONS_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
CHAT_MODEL=gemini-2.5-flash
FAST_CHAT_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001

# Domínios permitidos para CORS (separados por vírgula)
# Exemplo: http://localhost:8080,https://flixprev.com
VITE_ALLOWED_ORIGINS=http://localhost:8080